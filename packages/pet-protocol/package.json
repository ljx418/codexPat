{
  "name": "@agent-desktop-pet/pet-protocol",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && mkdir -p dist/schemas && cp schemas/pet-event.schema.json dist/schemas/pet-event.schema.json",
    "check": "tsc --noEmit",
    "test": "node --test --import tsx src/protocol.test.ts"
  },
  "dependencies": {
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.20.6",
    "typescript": "^5.6.0"
  }
}
