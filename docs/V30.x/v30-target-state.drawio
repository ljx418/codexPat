<mxfile host="app.diagrams.net" modified="2026-06-24T00:00:00.000Z" agent="Codex" version="24.7.17" type="device">
  <diagram id="v30-p1" name="1 目标体验与阶段边界">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="p1-title" value="V30 目标体验：从“图片会动”到“宠物在做可读动作”" style="rounded=1;whiteSpace=wrap;html=1;fontSize=28;fontStyle=1;fillColor=#111827;fontColor=#ffffff;strokeColor=#020617;" vertex="1" parent="1"><mxGeometry x="40" y="30" width="1520" height="80" as="geometry"/></mxCell>
        <mxCell id="p1-left" value="用户当前会感知到的问题&#xa;• running 像左右滑动&#xa;• success 像上下缩放&#xa;• error 像随机晃动&#xa;• need_input 依赖符号，不像猫在求回应&#xa;• sleeping 像坐姿下沉&#xa;• 预览只能看到帧，难判断动作是否合格&#xa;• frame delta 通过不代表动作好看" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;align=left;verticalAlign=top;spacing=18;fillColor=#fef2f2;strokeColor=#ef4444;" vertex="1" parent="1"><mxGeometry x="60" y="155" width="470" height="360" as="geometry"/></mxCell>
        <mxCell id="p1-mid" value="V30 完成后用户应看到&#xa;• 8 个 core actions 都有动作语义&#xa;• 每个动作有 storyboard 和关键姿势&#xa;• 动作来自高质量逐帧、2D 分层 rig 或已通过 QA 的 key-pose 候选&#xa;• contact sheet 能看清姿态变化&#xa;• animated playback 能读出动作&#xa;• old-vs-new 对照说明整图变形为什么失败&#xa;• QA table 给出安全 pass/fail reasonCode&#xa;• 只有 approved pack 能应用&#xa;• 可 rollback 到上一套可见资产" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;align=left;verticalAlign=top;spacing=18;fillColor=#ecfdf5;strokeColor=#10b981;" vertex="1" parent="1"><mxGeometry x="565" y="155" width="470" height="410" as="geometry"/></mxCell>
        <mxCell id="p1-right" value="阶段边界&#xa;允许声明&#xa;V30 semantic 2D pet animation quality passed for tested local action packs。&#xa;&#xa;不得声明&#xa;Petdex parity、任意猫自动生成、provider integration verified、3D ready、production release ready、Windows ready、cross-platform ready。&#xa;&#xa;边界含义&#xa;V30 是质量门禁，不是任意资产生成或发布能力。" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;align=left;verticalAlign=top;spacing=18;fillColor=#eff6ff;strokeColor=#3b82f6;" vertex="1" parent="1"><mxGeometry x="1070" y="155" width="470" height="410" as="geometry"/></mxCell>
        <mxCell id="p1-bottom" value="目标体验闭环：看懂动作语义 → 看见关键帧 → 播放动作 → 对比旧弱动作 → 查看 QA → 应用 approved pack → 不满意可 rollback" style="rounded=1;whiteSpace=wrap;html=1;fontSize=22;fontStyle=1;fillColor=#f8fafc;strokeColor=#64748b;" vertex="1" parent="1"><mxGeometry x="140" y="680" width="1320" height="100" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="v30-p2" name="2 当前架构到目标架构映射">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="p2-title" value="当前架构与目标架构的逐项关联：保留可用能力，改变验收标准" style="rounded=1;whiteSpace=wrap;html=1;fontSize=26;fontStyle=1;fillColor=#111827;fontColor=#ffffff;strokeColor=#020617;" vertex="1" parent="1"><mxGeometry x="40" y="30" width="1520" height="80" as="geometry"/></mxCell>
        <mxCell id="p2-h1" value="当前条目" style="rounded=1;whiteSpace=wrap;html=1;fontSize=20;fontStyle=1;fillColor=#fee2e2;strokeColor=#ef4444;" vertex="1" parent="1"><mxGeometry x="60" y="140" width="330" height="55" as="geometry"/></mxCell>
        <mxCell id="p2-h2" value="问题" style="rounded=1;whiteSpace=wrap;html=1;fontSize=20;fontStyle=1;fillColor=#ffedd5;strokeColor=#f97316;" vertex="1" parent="1"><mxGeometry x="410" y="140" width="330" height="55" as="geometry"/></mxCell>
        <mxCell id="p2-h3" value="V30 目标条目" style="rounded=1;whiteSpace=wrap;html=1;fontSize=20;fontStyle=1;fillColor=#dcfce7;strokeColor=#22c55e;" vertex="1" parent="1"><mxGeometry x="760" y="140" width="330" height="55" as="geometry"/></mxCell>
        <mxCell id="p2-h4" value="目标体验" style="rounded=1;whiteSpace=wrap;html=1;fontSize=20;fontStyle=1;fillColor=#dbeafe;strokeColor=#3b82f6;" vertex="1" parent="1"><mxGeometry x="1110" y="140" width="430" height="55" as="geometry"/></mxCell>
        <mxCell id="p2-r1" value="Source image / action sheet&#xa;已有图像或动作格子" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;spacing=12;fillColor=#fff1f2;strokeColor=#fda4af;" vertex="1" parent="1"><mxGeometry x="60" y="215" width="330" height="80" as="geometry"/></mxCell>
        <mxCell id="p2-r1b" value="动作含义不明确" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;spacing=12;fillColor=#fff7ed;strokeColor=#fdba74;" vertex="1" parent="1"><mxGeometry x="410" y="215" width="330" height="80" as="geometry"/></mxCell>
        <mxCell id="p2-r1c" value="Action Semantics Spec&#xa;先定义 8 动作含义" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;spacing=12;fillColor=#f0fdf4;strokeColor=#86efac;" vertex="1" parent="1"><mxGeometry x="760" y="215" width="330" height="80" as="geometry"/></mxCell>
        <mxCell id="p2-r1d" value="用户知道 running / success / error / need_input 应该表达什么" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;spacing=12;fillColor=#eff6ff;strokeColor=#93c5fd;" vertex="1" parent="1"><mxGeometry x="1110" y="215" width="430" height="80" as="geometry"/></mxCell>
        <mxCell id="p2-r2" value="crop action cell&#xa;裁切已有帧" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;spacing=12;fillColor=#fff1f2;strokeColor=#fda4af;" vertex="1" parent="1"><mxGeometry x="60" y="315" width="330" height="80" as="geometry"/></mxCell>
        <mxCell id="p2-r2b" value="只能得到帧，不能证明关键姿势" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;spacing=12;fillColor=#fff7ed;strokeColor=#fdba74;" vertex="1" parent="1"><mxGeometry x="410" y="315" width="330" height="80" as="geometry"/></mxCell>
        <mxCell id="p2-r2c" value="Storyboard / Key-pose Contract&#xa;记录关键姿势、节奏、禁止捷径" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;spacing=12;fillColor=#f0fdf4;strokeColor=#86efac;" vertex="1" parent="1"><mxGeometry x="760" y="315" width="330" height="80" as="geometry"/></mxCell>
        <mxCell id="p2-r2d" value="审核者能先看规格，再判断帧是否符合动作语义" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;spacing=12;fillColor=#eff6ff;strokeColor=#93c5fd;" vertex="1" parent="1"><mxGeometry x="1110" y="315" width="430" height="80" as="geometry"/></mxCell>
        <mxCell id="p2-r3" value="whole-image transform&#xa;缩放/平移/旋转整张图" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;spacing=12;fillColor=#fff1f2;strokeColor=#fda4af;" vertex="1" parent="1"><mxGeometry x="60" y="415" width="330" height="80" as="geometry"/></mxCell>
        <mxCell id="p2-r3b" value="像贴纸特效，容易伪装成动作" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;spacing=12;fillColor=#fff7ed;strokeColor=#fdba74;" vertex="1" parent="1"><mxGeometry x="410" y="415" width="330" height="80" as="geometry"/></mxCell>
        <mxCell id="p2-r3c" value="Route Priority + Motion QA&#xa;P0 高质量逐帧导入；P1 本地 2D 分层 rig；P2 provider key-pose 候选；整图变形 reject-only" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;spacing=12;fillColor=#f0fdf4;strokeColor=#86efac;" vertex="1" parent="1"><mxGeometry x="760" y="415" width="330" height="80" as="geometry"/></mxCell>
        <mxCell id="p2-r3d" value="用户不再把贴纸式整图变形当成合格动作；维护者知道哪条路线能形成通过证据" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;spacing=12;fillColor=#eff6ff;strokeColor=#93c5fd;" vertex="1" parent="1"><mxGeometry x="1110" y="415" width="430" height="80" as="geometry"/></mxCell>
        <mxCell id="p2-r4" value="frame delta / loop closure&#xa;检查帧差和循环" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;spacing=12;fillColor=#fff1f2;strokeColor=#fda4af;" vertex="1" parent="1"><mxGeometry x="60" y="515" width="330" height="80" as="geometry"/></mxCell>
        <mxCell id="p2-r4b" value="有变化不等于动作可读" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;spacing=12;fillColor=#fff7ed;strokeColor=#fdba74;" vertex="1" parent="1"><mxGeometry x="410" y="515" width="330" height="80" as="geometry"/></mxCell>
        <mxCell id="p2-r4c" value="Readability QA&#xa;姿态多样性、重心、轮廓、语义、同猫一致性" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;spacing=12;fillColor=#f0fdf4;strokeColor=#86efac;" vertex="1" parent="1"><mxGeometry x="760" y="515" width="330" height="80" as="geometry"/></mxCell>
        <mxCell id="p2-r4d" value="用户能看到动作为什么通过或失败" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;spacing=12;fillColor=#eff6ff;strokeColor=#93c5fd;" vertex="1" parent="1"><mxGeometry x="1110" y="515" width="430" height="80" as="geometry"/></mxCell>
        <mxCell id="p2-r5" value="preview / apply&#xa;展示并应用资产" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;spacing=12;fillColor=#fff1f2;strokeColor=#fda4af;" vertex="1" parent="1"><mxGeometry x="60" y="615" width="330" height="80" as="geometry"/></mxCell>
        <mxCell id="p2-r5b" value="预览与应用容易被误当成验收通过" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;spacing=12;fillColor=#fff7ed;strokeColor=#fdba74;" vertex="1" parent="1"><mxGeometry x="410" y="615" width="330" height="80" as="geometry"/></mxCell>
        <mxCell id="p2-r5c" value="Visual Review + Approved-only Apply + Rollback" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;spacing=12;fillColor=#f0fdf4;strokeColor=#86efac;" vertex="1" parent="1"><mxGeometry x="760" y="615" width="330" height="80" as="geometry"/></mxCell>
        <mxCell id="p2-r5d" value="用户先看对照证据，再安全应用，且可以恢复" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;spacing=12;fillColor=#eff6ff;strokeColor=#93c5fd;" vertex="1" parent="1"><mxGeometry x="1110" y="615" width="430" height="80" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="v30-p3" name="3 目标架构组件与数据流">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="p3-title" value="V30 目标架构组件：输入、职责、输出、体验" style="rounded=1;whiteSpace=wrap;html=1;fontSize=26;fontStyle=1;fillColor=#111827;fontColor=#ffffff;strokeColor=#020617;" vertex="1" parent="1"><mxGeometry x="40" y="30" width="1520" height="80" as="geometry"/></mxCell>
        <mxCell id="p3-a" value="1 语义规格&#xa;输入：8 core action IDs&#xa;职责：动作含义、情绪、禁止 shortcuts&#xa;输出：semantic checklist&#xa;体验：先知道动作应该像什么" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;verticalAlign=top;spacing=14;fillColor=#eff6ff;strokeColor=#3b82f6;" vertex="1" parent="1"><mxGeometry x="50" y="145" width="285" height="170" as="geometry"/></mxCell>
        <mxCell id="p3-b" value="2 Storyboard / Key-pose&#xa;输入：semantic checklist + metadata&#xa;职责：关键姿势、节奏、loop/transient&#xa;输出：storyboard evidence&#xa;体验：动作可被非开发者审查" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;verticalAlign=top;spacing=14;fillColor=#eef2ff;strokeColor=#6366f1;" vertex="1" parent="1"><mxGeometry x="365" y="145" width="285" height="170" as="geometry"/></mxCell>
        <mxCell id="p3-c" value="3 候选帧路线优先级&#xa;P0 manual high-quality frame import&#xa;P1 local 2D part rig&#xa;P2 provider key-pose candidate&#xa;Reject-only whole-image baseline&#xa;职责：产出候选但不能绕过 QA&#xa;体验：路线边界清楚" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;verticalAlign=top;spacing=14;fillColor=#f0fdf4;strokeColor=#22c55e;" vertex="1" parent="1"><mxGeometry x="680" y="145" width="285" height="190" as="geometry"/></mxCell>
        <mxCell id="p3-d" value="4 Local 2D Part Rig / Normalizer&#xa;输入：头、身体、前后腿、尾巴、耳朵、眼睛、动作关键姿势&#xa;职责：用部件姿态和曲线生成帧；统一 pet.json + frames/action/frame-###.png&#xa;输出：normalized pack 或 reasonCode&#xa;体验：动作不再僵硬地整体扭动" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;verticalAlign=top;spacing=14;fillColor=#f8fafc;strokeColor=#64748b;" vertex="1" parent="1"><mxGeometry x="995" y="145" width="285" height="190" as="geometry"/></mxCell>
        <mxCell id="p3-e" value="5 Motion Readability QA&#xa;输入：normalized pack + storyboard&#xa;职责：整图变形、姿态多样性、重心、轮廓、语义、loop、同猫、背景检查&#xa;输出：safe scores + pass/fail + reasonCodes&#xa;体验：弱动作有明确拒绝理由" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;verticalAlign=top;spacing=14;fillColor=#fef2f2;strokeColor=#ef4444;" vertex="1" parent="1"><mxGeometry x="260" y="380" width="330" height="230" as="geometry"/></mxCell>
        <mxCell id="p3-f" value="6 Visual Review / Isolated Preview&#xa;输入：QA result + frames + storyboard&#xa;职责：contact sheet、animated playback、old-vs-new、QA table；不发送 PetEvent，不改 CatStateMachine&#xa;输出：embedded HTML evidence&#xa;体验：一个页面看懂通过/失败" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;verticalAlign=top;spacing=14;fillColor=#fffbeb;strokeColor=#f59e0b;" vertex="1" parent="1"><mxGeometry x="635" y="380" width="360" height="230" as="geometry"/></mxCell>
        <mxCell id="p3-g" value="7 Approved-only Apply / Rollback / Runtime Renderer&#xa;输入：approved pack + target PetInstance + previous visible pack&#xa;职责：阻止 failed pack；只改目标宠物；保留并恢复旧资产；用安全 renderer payload 播放&#xa;输出：目标宠物可见语义动作 + 可回滚状态&#xa;体验：安全试用，失败不误用，不满意可恢复" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;verticalAlign=top;spacing=14;fillColor=#ecfdf5;strokeColor=#10b981;" vertex="1" parent="1"><mxGeometry x="1040" y="380" width="420" height="230" as="geometry"/></mxCell>
        <mxCell id="p3-flow" value="数据流：Action ID → semantic requirement → storyboard key poses → manual/rig/provider candidate frames → normalized pack → QA result → visual review → isolated preview → approved-only apply → rollback-capable runtime state" style="rounded=1;whiteSpace=wrap;html=1;fontSize=20;fontStyle=1;fillColor=#f8fafc;strokeColor=#64748b;" vertex="1" parent="1"><mxGeometry x="110" y="720" width="1380" height="95" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="v30-p4" name="4 开发计划与完成效果">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="p4-title" value="开发计划必须体现完成后的目标体验" style="rounded=1;whiteSpace=wrap;html=1;fontSize=26;fontStyle=1;fillColor=#111827;fontColor=#ffffff;strokeColor=#020617;" vertex="1" parent="1"><mxGeometry x="40" y="30" width="1520" height="80" as="geometry"/></mxCell>
        <mxCell id="p4-body" value="V30.0 Scope Freeze&#xa;完成效果：目标、边界、证据入口清楚；用户不会误解为任意猫/provider/3D/发布能力。&#xa;&#xa;V30.1 Storyboard / Key-pose&#xa;完成效果：8 个动作都有可读语义；用户知道每个动作应该表达什么。&#xa;&#xa;V30.2 Candidate Route / Normalization&#xa;完成效果：P0 高质量逐帧导入可先证明体验；P1 本地 2D 分层 rig 作为中期主线；P2 provider key-pose 只作候选；整图变形 reject-only；所有路线导出 normalized pack。&#xa;&#xa;V30.3 Motion Readability QA&#xa;完成效果：weak transform-only pack 被拒绝；semantic candidate 通过；差动作不会 silent pass。&#xa;&#xa;V30.4 Preview UX&#xa;完成效果：HTML 嵌入 storyboard、contact sheet、animated playback、old-vs-new、QA table；用户能快速理解差异。&#xa;&#xa;V30.5 Approved Apply / Rollback&#xa;完成效果：QA failed pack 不能应用；approved pack 只应用到目标宠物；用户可 rollback。&#xa;&#xa;V30.6 Final Gate&#xa;完成效果：final report、PRD/spec review、claim scan、security scan 闭环；审核者能复核 scoped pass。" style="rounded=1;whiteSpace=wrap;html=1;fontSize=17;align=left;verticalAlign=top;spacing=18;fillColor=#f8fafc;strokeColor=#64748b;" vertex="1" parent="1"><mxGeometry x="70" y="150" width="1460" height="620" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="v30-p5" name="5 验收门槛与用户体验">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="p5-title" value="验收门槛必须对应用户能体验到的功能" style="rounded=1;whiteSpace=wrap;html=1;fontSize=26;fontStyle=1;fillColor=#111827;fontColor=#ffffff;strokeColor=#020617;" vertex="1" parent="1"><mxGeometry x="40" y="30" width="1520" height="80" as="geometry"/></mxCell>
        <mxCell id="p5-left" value="验收门槛&#xa;1. 每个 action 有 storyboard 和 key poses&#xa;2. 路线边界清楚：manual import / local 2D part rig / provider candidate / weak baseline&#xa;3. 整图变形只能 reject-only&#xa;4. 候选包包含 8 个 core actions&#xa;5. active actions 有真实姿态变化&#xa;6. weak transform-only baseline 被拒绝&#xa;7. semantic candidate 有 QA pass evidence&#xa;8. HTML 嵌入视觉证据，不是 link-only&#xa;9. QA failed pack cannot apply&#xa;10. approved pack target-only apply&#xa;11. rollback restores previous visible pack" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;align=left;verticalAlign=top;spacing=18;fillColor=#ecfdf5;strokeColor=#10b981;" vertex="1" parent="1"><mxGeometry x="70" y="150" width="470" height="500" as="geometry"/></mxCell>
        <mxCell id="p5-mid" value="项目能达成的目标体验&#xa;• 用户看得懂 8 个动作在表达什么&#xa;• 用户看到动作来自逐帧、部件 rig 或通过 QA 的 key-pose 候选，而不是整图僵硬变形&#xa;• 用户能肉眼比较旧弱动作和新语义动作&#xa;• 用户能看到弱动作被拒绝的理由&#xa;• 用户只能应用合格动作包&#xa;• 用户试用时只改变目标宠物&#xa;• 用户不满意可以恢复旧资产&#xa;• 维护者能复核证据而不是相信口头声明" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;align=left;verticalAlign=top;spacing=18;fillColor=#eff6ff;strokeColor=#3b82f6;" vertex="1" parent="1"><mxGeometry x="565" y="150" width="470" height="500" as="geometry"/></mxCell>
        <mxCell id="p5-right" value="不能达成或不能声明&#xa;• 不是任意猫自动生成动画 ready&#xa;• 不是 provider integration verified&#xa;• 不是 Petdex parity achieved&#xa;• 不是 3D ready&#xa;• 不是生产发布 ready&#xa;• 不是 Windows ready&#xa;• 不是 cross-platform ready&#xa;&#xa;如果未来 evidence 破坏验收门槛，必须重新 blocked / failed / narrowed。" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;align=left;verticalAlign=top;spacing=18;fillColor=#fef2f2;strokeColor=#ef4444;" vertex="1" parent="1"><mxGeometry x="1060" y="150" width="470" height="500" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="v30-p6" name="6 里程碑与出门条件">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
