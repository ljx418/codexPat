<mxfile host="app.diagrams.net" modified="2026-06-17T00:00:00.000Z" agent="Codex" version="24.7.17" type="device">
  <diagram id="v30-semantic-animation" name="V30 语义动作质量">
    <mxGraphModel dx="2100" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2100" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="V30：语义角色动画质量阶段&#xa;目标：从“图片扭动”升级为“符合直觉、连贯、好看的宠物动作”" style="rounded=1;whiteSpace=wrap;html=1;fontSize=28;fontStyle=1;fillColor=#111827;fontColor=#ffffff;strokeColor=#020617;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="2020" height="86" as="geometry"/>
        </mxCell>
        <mxCell id="current" value="当前问题 / 已暴露缺口&#xa;&#xa;当前已有：&#xa;• 多帧 PNG 动作包&#xa;• contact sheet / HTML 预览&#xa;• 首尾闭合与 nonblank 检查&#xa;• target apply / rollback 基线&#xa;&#xa;核心不足：&#xa;• 动作像整图缩放/平移/旋转&#xa;• running 不像跑、success 不像庆祝&#xa;• error / warning / need_input 语义不清&#xa;• 帧差通过不代表动作好看&#xa;• 用户感知是“图片扭来扭去”" style="rounded=1;whiteSpace=wrap;html=1;fontSize=17;align=left;verticalAlign=top;spacing=16;fillColor=#fef2f2;strokeColor=#ef4444;" vertex="1" parent="1">
          <mxGeometry x="50" y="150" width="390" height="520" as="geometry"/>
        </mxCell>
        <mxCell id="target" value="目标架构&#xa;&#xa;Action Semantics Spec&#xa;↓&#xa;Storyboard / Key-pose Contract&#xa;↓&#xa;Candidate Frame Routes&#xa;• provider key-pose&#xa;• local 2D rig&#xa;• manual frame import&#xa;• weak baseline comparison&#xa;↓&#xa;Frame Normalizer&#xa;↓&#xa;Motion Readability QA&#xa;↓&#xa;Visual Review Queue&#xa;↓&#xa;Isolated Preview&#xa;↓&#xa;Approved Apply / Rollback" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;align=center;verticalAlign=middle;spacing=16;fillColor=#ecfeff;strokeColor=#0891b2;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="150" width="430" height="610" as="geometry"/>
        </mxCell>
        <mxCell id="semantics" value="动作语义门槛&#xa;&#xa;8 个 core actions 必须可读：&#xa;• idle：生命感，不漂移&#xa;• thinking：看向一侧/抬爪/扶下巴&#xa;• running：前冲、重心前移、跑步节奏&#xa;• success：预备、起跳/举爪、恢复&#xa;• warning：警觉/后缩/查看&#xa;• error：塌下/失衡/眩晕&#xa;• need_input：看向用户/举爪等待&#xa;• sleeping：卧倒/蜷缩/呼吸&#xa;&#xa;禁止把整图 transform 当作动作通过。" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;align=left;verticalAlign=top;spacing=16;fillColor=#fff7ed;strokeColor=#f97316;" vertex="1" parent="1">
          <mxGeometry x="980" y="150" width="500" height="470" as="geometry"/>
        </mxCell>
        <mxCell id="qa" value="Motion Readability QA&#xa;&#xa;Hard reject：&#xa;• whole-image-transform-only&#xa;• motion_amplitude_too_low&#xa;• key_pose_diversity_too_low&#xa;• action_semantics_unreadable&#xa;• identity_drift&#xa;• anchor_drift_too_high&#xa;• adjacent_frame_jump&#xa;• loop_closure_failed&#xa;• background_residue / off_canvas&#xa;&#xa;通过项仍需人工视觉验收。" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;align=left;verticalAlign=top;spacing=16;fillColor=#fdf2f8;strokeColor=#db2777;" vertex="1" parent="1">
          <mxGeometry x="1530" y="150" width="520" height="470" as="geometry"/>
        </mxCell>
        <mxCell id="plan" value="开发及验收计划&#xa;&#xa;V30.0 Scope freeze / drawio / claim 边界&#xa;V30.1 8 动作 storyboard + key-pose contract&#xa;V30.2 语义动作候选生成路线&#xa;V30.3 Motion readability QA 与弱动作拒绝&#xa;V30.4 old-vs-new 预览页 / contact sheet / 动图证据&#xa;V30.5 approved-only target apply / rollback&#xa;V30.6 final gate：HTML 嵌入视觉证据、回归、安全、claim scan" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;align=left;verticalAlign=top;spacing=16;fillColor=#f0fdf4;strokeColor=#22c55e;" vertex="1" parent="1">
          <mxGeometry x="50" y="830" width="590" height="390" as="geometry"/>
        </mxCell>
        <mxCell id="milestones" value="项目里程碑&#xa;&#xa;M30.0：文档和边界冻结&#xa;M30.1：动作语义与关键姿势完成&#xa;M30.2：至少一个 8 动作语义候选包&#xa;M30.3：弱 transform 包被拒绝，语义候选通过 QA&#xa;M30.4：HTML/Manager 能看 old-vs-new 动画对比&#xa;M30.5：目标宠物应用与回滚通过&#xa;M30.6：最终证据闭环" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;align=left;verticalAlign=top;spacing=16;fillColor=#eef2ff;strokeColor=#6366f1;" vertex="1" parent="1">
          <mxGeometry x="710" y="830" width="520" height="390" as="geometry"/>
        </mxCell>
        <mxCell id="exit" value="验收门槛 / 出门条件&#xa;&#xa;V30 passed 必须同时满足：&#xa;• V30.0-V30.5 evidence 存在&#xa;• 至少一个 8 动作语义包通过&#xa;• running / success / error / need_input 不看标签也能识别&#xa;• 弱 transform-only 资产被拒绝&#xa;• contact sheet + animated preview + old-vs-new 对比嵌入 HTML&#xa;• QA failed pack 不能 apply&#xa;• target-only apply / rollback 通过&#xa;• security scan + claim scan 通过&#xa;&#xa;否则 V30 blocked / failed，不得声明 Petdex parity。" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;align=left;verticalAlign=top;spacing=16;fillColor=#ffffff;strokeColor=#111827;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1300" y="780" width="750" height="470" as="geometry"/>
        </mxCell>
        <mxCell id="a1" edge="1" parent="1" source="current" target="target" style="endArrow=block;html=1;rounded=0;strokeWidth=3;strokeColor=#64748b;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a2" edge="1" parent="1" source="target" target="semantics" style="endArrow=block;html=1;rounded=0;strokeWidth=3;strokeColor=#64748b;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a3" edge="1" parent="1" source="semantics" target="qa" style="endArrow=block;html=1;rounded=0;strokeWidth=3;strokeColor=#64748b;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a4" edge="1" parent="1" source="plan" target="milestones" style="endArrow=block;html=1;rounded=0;strokeWidth=3;strokeColor=#64748b;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a5" edge="1" parent="1" source="milestones" target="exit" style="endArrow=block;html=1;rounded=0;strokeWidth=3;strokeColor=#64748b;"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
