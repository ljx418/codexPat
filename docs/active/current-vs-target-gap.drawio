        </mxCell>
        <mxCell id="p1-current" value="当前事实（绿色：已实现）&#xa;V38 已完成 public-photo scoped evidence&#xa;真实公开猫图 -&gt; 去元数据图 -&gt; 8 动作帧包&#xa;但输出仍像照片卡片/overlay 工程验证物&#xa;不能证明用户会喜欢" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="80" y="160" width="360" height="220" as="geometry" />
        </mxCell>
        <mxCell id="p1-gap" value="核心体验缺口（橙色：高风险）&#xa;猫本体没有角色化&#xa;动作主要不是身体部件在动&#xa;边框/圆点/标签抢占视觉&#xa;人类偏好可能失败&#xa;与 Petdex 级资产仍有明显差距" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#f97316;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="520" y="160" width="360" height="220" as="geometry" />
        </mxCell>
        <mxCell id="p1-target" value="V39 目标体验（黄色：待新增）&#xa;输入一张通过资格审查的猫照片&#xa;得到干净猫角色资产&#xa;头/耳/尾/爪/身体有局部动作&#xa;8 动作可读且有吸引力&#xa;可预览、应用、回滚" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#ca8a04;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="960" y="160" width="360" height="220" as="geometry" />
        </mxCell>
        <mxCell id="p1-claim" value="允许的最终窄声明&#xa;tested sample characterized 2D action asset scoped pass&#xa;&#xa;禁止正向声明&#xa;任意猫 ready / Petdex parity / provider verified&#xa;3D / production / Windows / cross-platform ready" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=16;" vertex="1" parent="1">
