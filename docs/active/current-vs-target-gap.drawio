        <mxCell id="p1-target" value="V40 目标体验（蓝色）&#10;同样本照片先进入 V40.3R4 受限 direct runner 预审：来源记录、主体裁切/遮罩、身份锚点、动作姿态条件。&#10;只有后续两个候选显式视觉通过，才能做 V40.4 包装、预览、目标应用、回滚。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="620" y="160" width="470" height="240" as="geometry" />
        </mxCell>
        <mxCell id="p1-tools" value="当前工具事实（黄色/红色）&#10;RTX 4090：可见。&#10;Ollama：advisory only，不生成图。&#10;Direct Runner smoke：passed scoped。&#10;prompt-only / img2img / V40.3R2：视觉失败。&#10;V40.3R3：remain_failed_or_blocked。&#10;V40.3R4：选择受限 direct runner 预审。&#10;宿主模板 GIF：generated_not_accepted。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1190" y="160" width="390" height="240" as="geometry" />
        </mxCell>
        <mxCell id="p1-no" value="禁止声明（红色）&#10;任意猫自动生成 ready&#10;Petdex parity&#10;provider integration verified&#10;Route B verified&#10;3D / production / Windows / cross-platform ready&#10;ComfyUI ready" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="90" y="500" width="430" height="260" as="geometry" />
        </mxCell>
        <mxCell id="p1-pass" value="V40 scoped pass 含义&#10;仅允许声明：tested local/public cat samples 在 No-WebUI 路线下，通过 Direct Local Runner 生成或显式导入、项目归一化、V39 对比、产品路径和扫描。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ccfbf1;strokeColor=#0f766e;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="620" y="500" width="470" height="260" as="geometry" />
        </mxCell>
        <mxCell id="p1-user" value="当前用户可见体验&#10;桌面右下角可看到内置橙色卡通猫，bridge 健康。&#10;这只证明 runtime 可见，不证明 V40 图生动作资产。&#10;如果仍是内置猫或原型感强，必须 fail/block。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1190" y="500" width="390" height="260" as="geometry" />
