<mxfile host="app.diagrams.net" modified="2026-06-24T20:30:00.000Z" agent="Codex" version="24.7.17" type="device">
  <diagram id="v31-page-1" name="1 目标体验与阶段边界">
    <mxGraphModel dx="1680" dy="980" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="p1-title" value="V31 目标体验与阶段边界" style="rounded=0;whiteSpace=wrap;html=1;fontSize=30;fontStyle=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="60" y="30" width="700" height="60" as="geometry"/></mxCell>
        <mxCell id="p1-current" value="当前事实&#xa;&#xa;• V30 语义动作门禁 scoped passed&#xa;• transform-only 弱动作可被拒绝&#xa;• semantic local candidate 可被接受&#xa;• 旧 flagship-work-cat-v2 简化线条猫已被拒绝&#xa;• V31 已有一个 named local 旗舰 8 动作资产 scoped passed&#xa;• 任意猫照片自动高质量动作资产仍 not-ready" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;align=left;verticalAlign=top;spacing=18;fillColor=#fff7ed;strokeColor=#f97316;" vertex="1" parent="1"><mxGeometry x="60" y="120" width="470" height="460" as="geometry"/></mxCell>
        <mxCell id="p1-target" value="V31 阶段结果与延续目标&#xa;&#xa;已通过：一个 named local 高质量 2D 猫动作资产可作为目标体验参考。&#xa;&#xa;未通过：任意猫照片自动生成高质量动作资产。&#xa;&#xa;V31.8-V31.13 目标：&#xa;• 可重复生产高质量动作资产&#xa;• 分层 rig 进入 runtime 证据或稳定 blocked&#xa;• named real sample set 照片到动作验收&#xa;• preview / apply / rollback 闭环&#xa;• final claim 只覆盖真实 evidence" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;align=left;verticalAlign=top;spacing=18;fillColor=#ecfdf5;strokeColor=#10b981;" vertex="1" parent="1"><mxGeometry x="565" y="120" width="500" height="460" as="geometry"/></mxCell>
        <mxCell id="p1-not-ready" value="本阶段仍不能声明&#xa;&#xa;• Petdex parity&#xa;• 任意猫自动动作资产 ready&#xa;• provider integration verified&#xa;• 3D ready&#xa;• production release ready&#xa;• Windows ready&#xa;• cross-platform ready&#xa;• MCP / Claude integration ready&#xa;• OS-level Codex window binding ready&#xa;• all Codex workflows verified&#xa;&#xa;文档完成也不能替代真实资产、真实样本和截图证据。" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;align=left;verticalAlign=top;spacing=18;fillColor=#fef2f2;strokeColor=#ef4444;" vertex="1" parent="1"><mxGeometry x="1100" y="120" width="440" height="460" as="geometry"/></mxCell>
        <mxCell id="p1-flow" value="当前体验路径：打开 V31 视觉报告 → 看到 named local 高质量旗舰猫 8 动作 → 查看旧占位/弱动作为什么失败 → 应用 approved 资产到目标猫 → 可回滚。延续目标：用 named sample set 证明照片路线，不能扩大为任意猫 ready。" style="rounded=1;whiteSpace=wrap;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;spacing=16;fillColor=#ffffff;strokeColor=#111827;" vertex="1" parent="1"><mxGeometry x="170" y="650" width="1260" height="120" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="v31-page-2" name="2 当前架构到目标架构">
    <mxGraphModel dx="1680" dy="980" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="p2-title" value="当前架构到 V31 目标架构" style="rounded=0;whiteSpace=wrap;html=1;fontSize=30;fontStyle=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="60" y="30" width="700" height="60" as="geometry"/></mxCell>
        <mxCell id="p2-current" value="当前架构能力&#xa;&#xa;apps/desktop&#xa;• main.ts：设置页、gallery、asset workflow、photo wizard、runtime renderer&#xa;• asset modules：V30 semantic QA、asset validator、photo-to-2D wizard、preview/apply/rollback&#xa;• bundled packs：flagship-work-cat-v2 仍是占位级 SVG&#xa;&#xa;src-tauri / packages&#xa;• runtime_setup.rs：Tauri runtime setup&#xa;• bridge/http：health、instances、events、visibility、diagnostics&#xa;• petctl：list / notify / diagnostics / managed smoke&#xa;&#xa;已具备：运行、预览、target-only apply、rollback、QA reasonCode。" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;verticalAlign=top;spacing=14;fillColor=#eff6ff;strokeColor=#2563eb;" vertex="1" parent="1"><mxGeometry x="60" y="120" width="470" height="610" as="geometry"/></mxCell>
        <mxCell id="p2-gap" value="当前缺口&#xa;&#xa;视觉资产质量&#xa;• 旧简化线条猫已拒绝&#xa;• named local 旗舰候选已 scoped passed&#xa;• 仍缺可重复生产与更多资产样本&#xa;&#xa;生产路线&#xa;• 有专业帧包候选证据&#xa;• 分层 rig 仍是路线合同，不是 runtime ready&#xa;&#xa;任意猫路线&#xa;• photo wizard 有边界和分支&#xa;• V31 仅 candidate-only scoped&#xa;• 没有证明自动生成高质量 8 动作&#xa;&#xa;验收风险&#xa;• 旗舰单样本可能被误读为任意猫 ready" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;verticalAlign=top;spacing=14;fillColor=#fff7ed;strokeColor=#f97316;" vertex="1" parent="1"><mxGeometry x="565" y="120" width="470" height="610" as="geometry"/></mxCell>
        <mxCell id="p2-target" value="V31 目标架构新增层&#xa;&#xa;Asset Source Layer&#xa;• 专业 sprite / frame pack&#xa;• layered part-rig / Spine-like / Live2D-like&#xa;• photo traits → character design&#xa;• provider key-pose candidate&#xa;• placeholder / transform reject baseline&#xa;&#xa;Production Layer&#xa;• license / consent / attribution&#xa;• character design contract&#xa;• action art direction&#xa;• normalized pack export&#xa;&#xa;Quality Layer&#xa;• V30 semantic QA&#xa;• V31 art quality QA&#xa;• same-cat identity QA&#xa;• action appeal / timing / 1x / 0.75x readability&#xa;&#xa;Experience Layer&#xa;• screenshot / playback report&#xa;• isolated preview&#xa;• approved-only apply&#xa;• rollback" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;verticalAlign=top;spacing=14;fillColor=#ecfdf5;strokeColor=#10b981;" vertex="1" parent="1"><mxGeometry x="1070" y="120" width="470" height="610" as="geometry"/></mxCell>
        <mxCell id="p2-a" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#64748b;" edge="1" parent="1" source="p2-current" target="p2-gap"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p2-b" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#64748b;" edge="1" parent="1" source="p2-gap" target="p2-target"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="v31-page-3" name="3 目标架构细化">
    <mxGraphModel dx="1680" dy="980" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="p3-title" value="V31 目标架构细化" style="rounded=0;whiteSpace=wrap;html=1;fontSize=30;fontStyle=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="60" y="30" width="700" height="60" as="geometry"/></mxCell>
        <mxCell id="p3-source" value="1 资产来源层&#xa;&#xa;P0 专业高质量帧包&#xa;• 人工 / 专业工具绘制&#xa;• 8 actions 多帧&#xa;• license / attribution&#xa;&#xa;P1 分层 rig / 专业动画工具&#xa;• 头、身体、四肢、尾巴、耳朵、眼睛&#xa;• 动作曲线和关键姿势&#xa;• 导出 normalized frames&#xa;&#xa;P2 照片个性化路线&#xa;• photo consent&#xa;• traits / character design&#xa;• key pose candidate&#xa;&#xa;P3 provider candidate&#xa;• 只产候选，不绕过 QA" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;align=left;verticalAlign=top;spacing=14;fillColor=#f8fafc;strokeColor=#475569;" vertex="1" parent="1"><mxGeometry x="50" y="130" width="350" height="560" as="geometry"/></mxCell>
        <mxCell id="p3-prod" value="2 生产层&#xa;&#xa;Character Design Contract&#xa;• 角色设定图&#xa;• 毛色/体型/脸型/尾巴/眼睛&#xa;• 同猫一致性目标&#xa;&#xa;Action Art Direction&#xa;• idle / thinking / running&#xa;• success / warning / error&#xa;• need_input / sleeping&#xa;• 关键姿势与节奏&#xa;&#xa;Normalizer&#xa;• safe pack id&#xa;• action id coverage&#xa;• frames/action/frame-###&#xa;• renderer payload boundary" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;align=left;verticalAlign=top;spacing=14;fillColor=#eff6ff;strokeColor=#2563eb;" vertex="1" parent="1"><mxGeometry x="440" y="130" width="350" height="560" as="geometry"/></mxCell>
        <mxCell id="p3-qa" value="3 质量层&#xa;&#xa;V30 Semantic QA&#xa;• transform-only detector&#xa;• key-pose diversity&#xa;• semantic checklist&#xa;• loop / adjacent delta&#xa;&#xa;V31 Art QA&#xa;• 非占位线条猫&#xa;• 体积感 / 表情 / 材质&#xa;• pose strength / action appeal&#xa;• 1x 和 0.75x 可读&#xa;• same-cat identity&#xa;• human visual review&#xa;&#xa;失败输出&#xa;• reasonCode&#xa;• blocked / failed evidence&#xa;• repair guidance" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;align=left;verticalAlign=top;spacing=14;fillColor=#fefce8;strokeColor=#ca8a04;" vertex="1" parent="1"><mxGeometry x="830" y="130" width="350" height="560" as="geometry"/></mxCell>
        <mxCell id="p3-exp" value="4 体验层&#xa;&#xa;Visual Evidence Report&#xa;• screenshots&#xa;• contact sheets&#xa;• playback / GIF / HTML&#xa;• old placeholder vs new quality&#xa;• QA table&#xa;&#xa;Runtime Flow&#xa;• isolated preview&#xa;• approved-only target apply&#xa;• failed asset blocked&#xa;• rollback restores previous pack&#xa;&#xa;用户结果&#xa;• 看到真正好看的 8 动作猫&#xa;• 知道照片路线是否通过或阻塞&#xa;• 不被 ready claim 误导" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;align=left;verticalAlign=top;spacing=14;fillColor=#ecfdf5;strokeColor=#10b981;" vertex="1" parent="1"><mxGeometry x="1220" y="130" width="330" height="560" as="geometry"/></mxCell>
        <mxCell id="p3-a" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#64748b;" edge="1" parent="1" source="p3-source" target="p3-prod"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p3-b" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#64748b;" edge="1" parent="1" source="p3-prod" target="p3-qa"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p3-c" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#64748b;" edge="1" parent="1" source="p3-qa" target="p3-exp"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="v31-page-4" name="4 开发与验收计划">
    <mxGraphModel dx="1680" dy="980" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="p4-title" value="V31 开发与验收计划" style="rounded=0;whiteSpace=wrap;html=1;fontSize=30;fontStyle=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="60" y="30" width="700" height="60" as="geometry"/></mxCell>
        <mxCell id="p4-phases" value="阶段结果与延续计划&#xa;&#xa;V31.0-V31.7&#xa;→ partial scoped：旗舰资产通过，照片路线 candidate-only&#xa;&#xa;V31.8 可重复资产生产&#xa;→ 多候选同一 QA 合同或稳定 blocked&#xa;&#xa;V31.9 分层 rig runtime 路线&#xa;→ normalized frames / runtime payload 或稳定 blocked&#xa;&#xa;V31.10 named photo sample set&#xa;→ 清晰、困难、blocked、negative 样本&#xa;&#xa;V31.11 photo action closure&#xa;→ QA 后 preview / apply / rollback&#xa;&#xa;V31.12 continuation E2E&#xa;→ 真实数据报告&#xa;&#xa;V31.13 final gate&#xa;→ scoped / partial / blocked / failed" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;verticalAlign=top;spacing=14;fillColor=#eff6ff;strokeColor=#2563eb;" vertex="1" parent="1"><mxGeometry x="60" y="120" width="500" height="650" as="geometry"/></mxCell>
        <mxCell id="p4-acceptance" value="每阶段验收动作&#xa;&#xa;必须产出：&#xa;• 真实 evidence 文件&#xa;• PRD / spec review&#xa;• claim scan&#xa;• security scan&#xa;• passed / blocked / failed 结论&#xa;&#xa;视觉阶段必须产出：&#xa;• HTML 报告&#xa;• 自动化截图或播放证据&#xa;• old placeholder vs new quality 对比&#xa;• 人工视觉 rubric&#xa;&#xa;照片阶段必须产出：&#xa;• real sample set&#xa;• consent/privacy boundary&#xa;• identity / visual / motion QA&#xa;• blocked sample reasonCodes&#xa;&#xa;不通过则回到开发计划，不 silent pass。" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;verticalAlign=top;spacing=14;fillColor=#fefce8;strokeColor=#ca8a04;" vertex="1" parent="1"><mxGeometry x="600" y="120" width="440" height="650" as="geometry"/></mxCell>
        <mxCell id="p4-user" value="延续完成后的目标体验&#xa;&#xa;资产生产：&#xa;• 不只依赖一个旗舰候选&#xa;• 多候选用同一美术 / 语义 QA&#xa;• 分层 rig 若可行，能输出真实 frames / payload&#xa;&#xa;照片路线：&#xa;• 用户照片先进入 named sample set 口径&#xa;• 系统给出候选或 blocked 原因&#xa;• 通过的候选可预览、应用、回滚&#xa;• 失败样本不隐藏、不 silent pass&#xa;&#xa;最终声明：&#xa;• 只能说 evidence 覆盖的 scoped 能力。" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;verticalAlign=top;spacing=14;fillColor=#ecfdf5;strokeColor=#10b981;" vertex="1" parent="1"><mxGeometry x="1080" y="120" width="460" height="650" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="v31-page-5" name="5 里程碑与证据">
    <mxGraphModel dx="1680" dy="980" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="p5-title" value="V31 里程碑与证据" style="rounded=0;whiteSpace=wrap;html=1;fontSize=30;fontStyle=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="60" y="30" width="700" height="60" as="geometry"/></mxCell>
        <mxCell id="p5-m1" value="M31.0-M31.1&#xa;&#xa;文档和美术门槛&#xa;• PRD / architecture / plan / acceptance / milestones / claim / gap / audit&#xa;• drawio ≤ 8 页&#xa;• 当前占位猫失败证据&#xa;• 高质量视觉 rubric&#xa;&#xa;Exit：维护者知道目标体验是什么，知道当前猫为什么失败。" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;verticalAlign=top;spacing=14;fillColor=#eff6ff;strokeColor=#2563eb;" vertex="1" parent="1"><mxGeometry x="60" y="130" width="330" height="260" as="geometry"/></mxCell>
        <mxCell id="p5-m2" value="M31.2-M31.3&#xa;&#xa;旗舰资产与视觉报告&#xa;• 高质量 8 动作资产路线&#xa;• license / attribution&#xa;• contact sheets&#xa;• playback / screenshots&#xa;• 1x / 0.75x&#xa;• target-only apply / rollback&#xa;&#xa;Exit：scoped passed，用户能看到可作为目标体验的 named local 旗舰动作猫。" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;verticalAlign=top;spacing=14;fillColor=#ecfdf5;strokeColor=#10b981;" vertex="1" parent="1"><mxGeometry x="430" y="130" width="330" height="260" as="geometry"/></mxCell>
        <mxCell id="p5-m3" value="M31.4&#xa;&#xa;可复用生产路线&#xa;• layered rig / Spine-like / Live2D-like 方案&#xa;• 部件：头、身体、四肢、尾巴、耳朵、眼睛&#xa;• 动作曲线 / 关键姿势&#xa;• 导出 normalized frames&#xa;• 接入 V30/V31 QA&#xa;&#xa;Exit：后续资产不用依赖整图变形。" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;verticalAlign=top;spacing=14;fillColor=#fefce8;strokeColor=#ca8a04;" vertex="1" parent="1"><mxGeometry x="800" y="130" width="330" height="260" as="geometry"/></mxCell>
        <mxCell id="p5-m4" value="M31.5-M31.6&#xa;&#xa;任意猫照片路线与真实数据&#xa;• real photo sample set&#xa;• consent / privacy&#xa;• traits / character design&#xa;• key pose candidate&#xa;• identity QA&#xa;• visual QA&#xa;• motion QA&#xa;• blocked sample reasonCodes&#xa;&#xa;Exit：只能对真实样本 scoped passed，否则 blocked / failed。" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;verticalAlign=top;spacing=14;fillColor=#fff7ed;strokeColor=#f97316;" vertex="1" parent="1"><mxGeometry x="1170" y="130" width="330" height="260" as="geometry"/></mxCell>
        <mxCell id="p5-final" value="M31.7 / M31.13 Final Gates&#xa;&#xa;M31.7 当前结果：partial scoped。旗舰资产通过，照片自动生成仍 not-ready。&#xa;&#xa;M31.8-M31.13 延续里程碑必须汇总：&#xa;• repeatable asset production evidence&#xa;• layered rig runtime evidence / stable blocked reason&#xa;• named real sample set&#xa;• photo action preview / apply / rollback&#xa;• user-visible target experience status&#xa;• claim scan / security scan&#xa;• narrow final claim&#xa;&#xa;不得 silent pass。" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;spacing=16;fillColor=#ffffff;strokeColor=#111827;" vertex="1" parent="1"><mxGeometry x="220" y="510" width="1160" height="240" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="v31-page-6" name="6 验收门槛与出门条件">
    <mxGraphModel dx="1680" dy="980" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="p6-title" value="V31 验收门槛与出门条件" style="rounded=0;whiteSpace=wrap;html=1;fontSize=30;fontStyle=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="60" y="30" width="760" height="60" as="geometry"/></mxCell>
        <mxCell id="p6-art" value="高质量旗舰资产 Pass 门槛&#xa;&#xa;• 不是简化线条占位猫&#xa;• 角色有体积感、表情、轮廓和材质细节&#xa;• 8 core actions 全覆盖&#xa;• active actions 不看标签也能识别&#xa;• running / success / error / need_input 有强姿态&#xa;• idle / sleeping 有生命感但不漂移&#xa;• 1x 和 0.75x 可读&#xa;• loop 不闪帧&#xa;• license / attribution 完整&#xa;• HTML/截图/播放证据嵌入" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;verticalAlign=top;spacing=14;fillColor=#ecfdf5;strokeColor=#10b981;" vertex="1" parent="1"><mxGeometry x="60" y="120" width="460" height="510" as="geometry"/></mxCell>
        <mxCell id="p6-photo" value="任意猫照片路线 Pass 门槛&#xa;&#xa;必须基于 named real sample set：&#xa;• 清晰猫照片&#xa;• 侧面/局部身体照片&#xa;• 长毛或复杂花纹猫&#xa;• 低质量 blocked 样本&#xa;• 非猫/不安全输入样本&#xa;&#xa;必须证明：&#xa;• consent / privacy boundary&#xa;• traits / character design&#xa;• same-cat identity QA&#xa;• 8 action candidates&#xa;• visual art QA&#xa;• semantic motion QA&#xa;• blocked / failed reasonCodes&#xa;• preview / apply / rollback" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;verticalAlign=top;spacing=14;fillColor=#eff6ff;strokeColor=#2563eb;" vertex="1" parent="1"><mxGeometry x="570" y="120" width="460" height="510" as="geometry"/></mxCell>
        <mxCell id="p6-nogo" value="No-Go / 出门失败条件&#xa;&#xa;• 没有真实视觉证据&#xa;• flagship 仍像占位线条猫&#xa;• 只靠文字声称质量达标&#xa;• whole-image transform 被当作最终路线&#xa;• provider 输出绕过本地 QA&#xa;• 任意猫 ready 无真实样本集&#xa;• failed asset 可以 apply&#xa;• rollback 失败&#xa;• claim/security scan 失败&#xa;• final gate 用 silent pass 代替 blocked/failed" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;align=left;verticalAlign=top;spacing=14;fillColor=#fef2f2;strokeColor=#ef4444;" vertex="1" parent="1"><mxGeometry x="1080" y="120" width="460" height="510" as="geometry"/></mxCell>
        <mxCell id="p6-claim" value="最终声明已收窄：当前只能说 named local flagship 资产 scoped passed。V31.8-V31.13 完成后也只能声明 repeatable production 或 named sample set 覆盖的 scoped 能力，不能说任意猫自动生成 ready。" style="rounded=1;whiteSpace=wrap;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;spacing=16;fillColor=#ffffff;strokeColor=#111827;" vertex="1" parent="1"><mxGeometry x="170" y="700" width="1260" height="120" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
