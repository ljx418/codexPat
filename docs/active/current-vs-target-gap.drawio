  <diagram id="4 单照片到动作资产技术路径" name="4 单照片到动作资产技术路径">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" page="1" pageWidth="1700" pageHeight="1100">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p4-title" value="单照片到 2D 动作资产：不是整图变形，而是先理解猫再生成动作帧" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=22;fontStyle=1;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="70" y="40" width="1560" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p4-s1" value="1 输入照片 / 样本&#10;输入：真实 tested cat photo 或已授权本地样本。&#10;输出：sampleId + safe sourceRef。&#10;失败：来源/授权不清楚则 blocked。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="90" y="160" width="260" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p4-s2" value="2 同样本 V39 基线&#10;输入：sampleId。&#10;输出：V39 character/contact sheet/preview refs。&#10;用途：后续 V40 必须比它更好；V39 不是 V40 通过证据。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="420" y="160" width="260" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p4-s3" value="3 猫主体理解&#10;输入：照片。&#10;输出：SubjectMaskAndCropPlan。&#10;目的：隔离猫身体和轮廓，避免把整张背景图当贴纸扭动。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="750" y="160" width="260" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p4-s4" value="4 身份锚点 + 动作姿态&#10;输出：IdentityAnchorPack（花色/脸型/比例/尾巴/耳朵）&#10;输出：ActionPoseConditionPack。&#10;V40 资产动作固定：idle/walk/jump/sleep/eat/play/alert/celebrate。&#10;产品状态动作必须映射到这些资产动作。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1080" y="160" width="260" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p4-s5" value="5 本地直接生成&#10;DirectDiffusersFrameRunner 使用本地模型组件。&#10;禁止：WebUI、ComfyUI、云 provider、Ollama 生成图。&#10;Ollama 只可生成 prompt/rubric/review 摘要。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1410" y="160" width="220" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p4-s6" value="6 候选帧序列&#10;输出：CandidateFrameSequence，按动作保存安全 refs/thumbnails/manifest summary。&#10;不是：单张漂亮图、整图 transform、模板 GIF。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="260" y="510" width="300" height="190" as="geometry" />
        </mxCell>
        <mxCell id="p4-s7" value="7 质量审查 + V39 对比&#10;CandidateQualityReview 检查：同猫身份、动作可读、小尺寸可爱度、伪影、安全。&#10;V39SameSampleComparison：必须优于同样本 V39。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="700" y="510" width="300" height="190" as="geometry" />
        </mxCell>
        <mxCell id="p4-s8" value="8 产品包装（仍 No-Go）&#10;V40.3R5 预审通过 + V40.3R6 两个同样本候选视觉通过后，才能进入 V40.4 包装、preview/apply/rollback、中文 HTML。&#10;否则 failed/blocked。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ccfbf1;strokeColor=#0f766e;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1140" y="510" width="300" height="190" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="5 代码实体与数据流" name="5 代码实体与数据流">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" page="1" pageWidth="1700" pageHeight="1100">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p5-title" value="V40 代码实体与数据流：从照片到候选动作帧的审计链路" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=22;fontStyle=1;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="70" y="40" width="1560" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p5-v39" value="已实现复用&#10;v39-characterized-action-assets.ts&#10;提供 same-sample V39 baseline / fallback。&#10;角色：比较对象和回退，不是 V40 生成结果。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="90" y="150" width="350" height="210" as="geometry" />
        </mxCell>
        <mxCell id="p5-orch" value="待编排控制器&#10;LocalImageCandidateOrchestrator&#10;绑定 sampleId、baselineV39Ref、route、runId、reasonCodes。&#10;拒绝无 source/mask/identity/action 预审的运行。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="500" y="150" width="350" height="210" as="geometry" />
        </mxCell>
        <mxCell id="p5-webui" value="输入与预审实体&#10;PhotoSafetyIntake&#10;SourceAndLicenseRecord&#10;SubjectMaskAndCropPlan&#10;IdentityAnchorPack&#10;ActionPoseConditionPack&#10;作用：让模型知道是哪只猫、做什么动作。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="910" y="150" width="350" height="210" as="geometry" />
        </mxCell>
        <mxCell id="p5-ollama" value="生成与文本辅助&#10;DirectDiffusersFrameRunner：本地模型帧生成。&#10;OllamaPromptReviewAdapter：advisory only，只给文本建议。&#10;禁止：WebUI/ComfyUI/云 provider/Ollama 生图。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1320" y="150" width="280" height="210" as="geometry" />
        </mxCell>
        <mxCell id="p5-gates" value="输出与质量门&#10;CandidateFrameSequence：动作帧候选。&#10;CandidateQualityReview：拒绝身份漂移、照片卡、动作弱、伪影。&#10;V39SameSampleComparison：必须优于 V39。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="300" y="510" width="470" height="210" as="geometry" />
        </mxCell>
        <mxCell id="p5-product" value="产品路径（待解锁）&#10;HybridAssetNormalizationGate + preview/apply/rollback。&#10;进入条件：V40.3R5 预审通过，V40.3R6 至少两个 same-sample 候选显式视觉通过。&#10;当前内置橙色猫只证明 runtime 可见。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ccfbf1;strokeColor=#0f766e;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="910" y="510" width="470" height="210" as="geometry" />
        </mxCell>
        <mxCell id="p5-e1" value="safe source + sampleId" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#334155;fontSize=12;endArrow=block;endFill=1;" edge="1" parent="1" source="p5-v39" target="p5-orch">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p5-e2" value="mask + identity + action controls" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#334155;fontSize=12;endArrow=block;endFill=1;" edge="1" parent="1" source="p5-orch" target="p5-webui">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p5-e3" value="local generated frame refs" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d97706;fontSize=12;endArrow=block;endFill=1;" edge="1" parent="1" source="p5-ollama" target="p5-gates">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p5-e4" value="quality review + V39 comparison" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#334155;fontSize=12;endArrow=block;endFill=1;" edge="1" parent="1" source="p5-webui" target="p5-gates">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p5-e5" value="only accepted candidates enter product gate" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#334155;fontSize=12;endArrow=block;endFill=1;" edge="1" parent="1" source="p5-gates" target="p5-product">
