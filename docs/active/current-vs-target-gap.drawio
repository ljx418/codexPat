  </diagram>
  <diagram id="6 开发及阶段验收计划" name="6 开发及阶段验收计划">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" page="1" pageWidth="1700" pageHeight="1100">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p6-title" value="V40 开发及阶段验收计划：R4 文档路线 -&gt; R5 预审 -&gt; R6 候选生成 -&gt; V40.4" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=22;fontStyle=1;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="70" y="40" width="1560" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p6-1" value="V40.1 已完成&#10;ComfyUI blocked baseline。&#10;出门：保留 evidence，不作为 readiness。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=14;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="150" width="250" height="160" as="geometry" />
        </mxCell>
        <mxCell id="p6-1a" value="V40.1A Direct Runner smoke&#10;passed scoped：验证项目自有 runner、GPU、依赖、模型摘要、安全输出目录。&#10;不证明生成质量。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="390" y="150" width="250" height="160" as="geometry" />
        </mxCell>
        <mxCell id="p6-2" value="V40.2 合同&#10;passed scoped：No-WebUI run request、candidate summary、reason codes、safe refs。&#10;出门：安全单测。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="700" y="150" width="250" height="160" as="geometry" />
        </mxCell>
        <mxCell id="p6-3" value="V40.3 / V40.3R / V40.3R2&#10;failed/blocked：prompt-only failed；img2img failed；identity-conditioned generated but visual failed。&#10;不能进入 V40.4。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=14;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1010" y="150" width="250" height="160" as="geometry" />
        </mxCell>
        <mxCell id="p6-4" value="V40.3R4 当前门槛&#10;文档已选择受限 direct runner。&#10;出门：PRD/架构/drawio/scans 一致。&#10;不能生成资产，不能解锁 V40.4。&#10;下一步必须进入 V40.3R5 预开发审计。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=14;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1320" y="150" width="250" height="160" as="geometry" />
        </mxCell>
        <mxCell id="p6-5" value="V40.3R5 预开发审计&#10;证明：source/license、sample matrix、local model/control、mask/crop、identity anchors、action pose controls、安全 runner、visual rubric。&#10;还必须记录动作映射：product states -&gt; V40 asset actions。&#10;缺一项即 blocked/failed。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=14;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="390" y="500" width="280" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p6-6" value="V40.3R6 候选帧生成&#10;只在 R5 passed 后执行。&#10;输出 CandidateFrameSequence + CandidateQualityReview + V39SameSampleComparison。&#10;两个同样本视觉通过才允许 V40.4。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ccfbf1;strokeColor=#0f766e;fontSize=14;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="710" y="500" width="280" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p6-7" value="V40.4-V40.7（No-Go）&#10;V40.4 包装与 8 动作覆盖；V40.5 preview/apply/rollback；V40.6 中文 HTML；V40.7 final gate。&#10;进入条件：R6 两个视觉通过候选。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=14;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1030" y="500" width="280" height="170" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="7 项目里程碑与风险闭环" name="7 项目里程碑与风险闭环">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" page="1" pageWidth="1700" pageHeight="1100">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p7-title" value="V40 项目里程碑与风险闭环：已失败路线不能被当成通过路线" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=22;fontStyle=1;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="70" y="40" width="1560" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p7-m1" value="M1 已完成/需同步&#10;PRD/架构/计划/验收/drawio 全部指向 V40 no-WebUI。&#10;本轮修订重点：同步 V40.3R2 failed 与 V40.3R4 候选来源门槛。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="90" y="160" width="340" height="190" as="geometry" />
        </mxCell>
        <mxCell id="p7-m2" value="M2 Direct Runner readiness&#10;passed scoped。&#10;风险已暴露：模型/路线不适合动作资产，不能把 readiness 当质量通过。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="500" y="160" width="340" height="190" as="geometry" />
        </mxCell>
        <mxCell id="p7-m3" value="M3 候选质量提升&#10;当前 failed/blocked。&#10;prompt-only、img2img、V40.3R2 均未达目标体验。&#10;V40.3R4 选择受限 direct runner，但只能先做预审，不能声明资产 ready。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="910" y="160" width="340" height="190" as="geometry" />
        </mxCell>
        <mxCell id="p7-m4" value="M4 产品闭环&#10;当前 No-Go。&#10;只有 accepted candidates 才能 preview/apply/rollback；当前桌面猫仍是内置资产。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ccfbf1;strokeColor=#0f766e;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1320" y="160" width="260" height="190" as="geometry" />
        </mxCell>
        <mxCell id="p7-risk" value="高风险闭环&#10;1 已失败路线不得重写成通过。&#10;2 V40.3R4 只冻结受限 direct runner。&#10;3 V40.3R5 缺少来源、遮罩、身份锚点、动作姿态或本地控制组件即 blocked/failed。&#10;4 V40.3R6 不得产出整图 transform / 模板 GIF / photo-card。&#10;5 没有两个视觉通过候选：V40.4-V40.7 No-Go。&#10;6 证据泄露路径/提示词/图片：security fail。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="250" y="520" width="1200" height="240" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="8 验收门槛与出门条件" name="8 验收门槛与出门条件">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" page="1" pageWidth="1700" pageHeight="1100">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p8-title" value="V40 No-WebUI 验收门槛与出门条件：体验可见、证据真实、声明收窄" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=22;fontStyle=1;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="70" y="40" width="1560" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p8-user" value="用户体验门槛（青色）&#10;- 能看到源样本、V39 对照和 V40 候选&#10;- 8 动作在桌宠尺寸可读&#10;- 角色比 V39 更有设计感&#10;- 可预览、可目标应用、可回滚&#10;- 当前内置橙色猫只算 runtime 可见，不算 V40 资产通过" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ccfbf1;strokeColor=#0f766e;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="90" y="170" width="430" height="280" as="geometry" />
        </mxCell>
        <mxCell id="p8-tech" value="技术门槛（蓝色）&#10;- Direct Runner smoke 不是质量通过&#10;- Ollama 仅辅助文本审查&#10;- V40.3R4 已选受限 direct runner&#10;- V40.3R5 必须有 source/license、mask/crop、identity anchors、action pose controls、动作映射&#10;- 输出归一化为安全 manifest&#10;- 拒绝 raw path/prompt/payload/image&#10;- 不污染 active pack" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="630" y="170" width="430" height="280" as="geometry" />
        </mxCell>
        <mxCell id="p8-quality" value="质量门槛（黄色）&#10;- same-sample V39/V40 对比&#10;- 身份一致性&#10;- 非 transform-only&#10;- 动作语义明确&#10;- human preference gate&#10;- 视觉不佳必须 fail/block" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1170" y="170" width="430" height="280" as="geometry" />
        </mxCell>
        <mxCell id="p8-exit" value="Final gate 出门条件（紫色）&#10;1 V40.3R4 文档路线一致。&#10;2 V40.3R5 受限 direct runner 预审通过。&#10;3 V40.3R6 两个同样本候选显式视觉通过，并优于 V39。&#10;4 V40.4 安全包装和 8 动作覆盖通过。&#10;5 产品 preview/apply/rollback 通过。&#10;6 HTML 报告可读且证据非空。&#10;7 claim/security scan 通过；否则 failed/blocked。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="260" y="570" width="1180" height="250" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
