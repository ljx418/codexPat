        <mxCell id="p6-c" value="场景 C：审查报告&#xa;源图 vs 角色图&#xa;part map / rig&#xa;contact sheet / GIF&#xa;产品截图&#xa;claim/security 边界" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#ca8a04;fontSize=16;" vertex="1" parent="1">
