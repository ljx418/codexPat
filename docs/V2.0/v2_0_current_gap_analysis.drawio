        <mxCell id="plan_body" value="Phase 2.0：V1.0 baseline freeze（done）&lt;br&gt;Phase 2.1：Workflow Integration Templates（done）&lt;br&gt;Phase 2.2：Settings &amp; diagnostics polish（done）&lt;br&gt;Phase 2.3：Cat experience polish（done）&lt;br&gt;Phase 2.4：Distribution readiness（done）&lt;br&gt;Final acceptance report：passed&lt;br&gt;Next：Windows / signing / optional adapters planning" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;align=left;spacingLeft=18;fontSize=15" vertex="1" parent="1">
